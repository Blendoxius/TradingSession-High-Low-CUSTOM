// HELPER FUNCTIONS
f_session_started(session) =>
    na(session[1]) and not na(session)

f_session_ended(session) =>
    not na(session[1]) and na(session)

f_get_session(session_time, timezone) =>
    time(timeframe.period, session_time, timezone)

f_get_line_style(style_string) =>
    style_string == "Solid" ? line.style_solid : style_string == "Dashed" ? line.style_dashed : line.style_dotted

// SESSION CALCULATIONS
tokyo_session = f_get_session(i_tokyo_time, i_timezone)
london_session = f_get_session(i_london_time, i_timezone)
newyork_session = f_get_session(i_newyork_time, i_timezone)
sydney_session = f_get_session(i_sydney_time, i_timezone)

// SESSION BACKGROUNDS
bgcolor(i_tokyo_enabled and not na(tokyo_session) ? i_tokyo_bg_color : na)
bgcolor(i_london_enabled and not na(london_session) ? i_london_bg_color : na)
bgcolor(i_newyork_enabled and not na(newyork_session) ? i_newyork_bg_color : na)
bgcolor(i_sydney_enabled and not na(sydney_session) ? i_sydney_bg_color : na)

// SESSION LABELS
if i_tokyo_enabled and i_tokyo_show_label and f_session_started(tokyo_session)
    label.new(x=bar_index, y=high, text="TOKYO", style=label.style_label_down, color=color.new(color.yellow, 20), textcolor=color.black, size=size.small)

if i_london_enabled and i_london_show_label and f_session_started(london_session)
    label.new(x=bar_index, y=high, text="LONDON", style=label.style_label_down, color=color.new(color.blue, 20), textcolor=color.white, size=size.small)

