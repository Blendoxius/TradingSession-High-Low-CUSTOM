    label.new(x=bar_index, y=high, text="SYDNEY", style=label.style_label_down, color=color.new(color.purple, 20), textcolor=color.white, size=size.small)

// SESSION HIGH/LOW TRACKING
var float tokyo_session_high = na
var float tokyo_session_low = na
var int tokyo_session_high_bar = na
var int tokyo_session_low_bar = na

var float london_session_high = na
var float london_session_low = na
var int london_session_high_bar = na
var int london_session_low_bar = na

var float newyork_session_high = na
var float newyork_session_low = na
var int newyork_session_high_bar = na
var int newyork_session_low_bar = na

var float sydney_session_high = na
var float sydney_session_low = na
var int sydney_session_high_bar = na
var int sydney_session_low_bar = na

// === ARRAYS ===
var line[] sessionHighLines = array.new_line()
var float[] sessionHighVals = array.new_float()
var int[] sessionHighBars = array.new_int()
var string[] sessionHighSessions = array.new_string()
var bool[] sessionHighActive = array.new_bool()
var bool[] sessionHighBroken = array.new_bool()
var bool[] sessionHighTouched = array.new_bool()

var line[] sessionLowLines = array.new_line()
var float[] sessionLowVals = array.new_float()
var int[] sessionLowBars = array.new_int()
var string[] sessionLowSessions = array.new_string()
var bool[] sessionLowActive = array.new_bool()
var bool[] sessionLowBroken = array.new_bool()
var bool[] sessionLowTouched = array.new_bool()

// HELPER FUNCTION TO COUNT LINES PER SESSION
f_count_session_lines(session_name) =>
    high_count = 0
    low_count = 0
    
    // Count high lines
    if array.size(sessionHighLines) > 0
        for i = 0 to array.size(sessionHighLines) - 1
            if array.get(sessionHighSessions, i) == session_name
                high_count += 1
    
    // Count low lines
    if array.size(sessionLowLines) > 0
        for i = 0 to array.size(sessionLowLines) - 1
            if array.get(sessionLowSessions, i) == session_name
                low_count += 1
    
    high_count + low_count

// HELPER FUNCTION TO REMOVE OLDEST LINE FROM SESSION
f_remove_oldest_session_line(session_name) =>
    // Find oldest high line from this session
    oldest_high_idx = -1
    oldest_high_bar = 999999
    
    if array.size(sessionHighLines) > 0
        for i = 0 to array.size(sessionHighLines) - 1
            if array.get(sessionHighSessions, i) == session_name
                bar_idx = array.get(sessionHighBars, i)
                if bar_idx < oldest_high_bar
                    oldest_high_bar := bar_idx
                    oldest_high_idx := i
    
    // Find oldest low line from this session
    oldest_low_idx = -1
    oldest_low_bar = 999999
    
    if array.size(sessionLowLines) > 0
        for i = 0 to array.size(sessionLowLines) - 1
            if array.get(sessionLowSessions, i) == session_name
                bar_idx = array.get(sessionLowBars, i)
                if bar_idx < oldest_low_bar
                    oldest_low_bar := bar_idx
                    oldest_low_idx := i
    
    // Remove the oldest line (high or low)
    if oldest_high_idx >= 0 and oldest_low_idx >= 0
        if oldest_high_bar < oldest_low_bar
            // Remove high line
            line.delete(array.get(sessionHighLines, oldest_high_idx))
            array.remove(sessionHighLines, oldest_high_idx)
            array.remove(sessionHighVals, oldest_high_idx)
            array.remove(sessionHighBars, oldest_high_idx)
            array.remove(sessionHighSessions, oldest_high_idx)
            array.remove(sessionHighActive, oldest_high_idx)
            array.remove(sessionHighBroken, oldest_high_idx)
            array.remove(sessionHighTouched, oldest_high_idx)
        else
            // Remove low line
            line.delete(array.get(sessionLowLines, oldest_low_idx))
            array.remove(sessionLowLines, oldest_low_idx)
            array.remove(sessionLowVals, oldest_low_idx)
            array.remove(sessionLowBars, oldest_low_idx)
            array.remove(sessionLowSessions, oldest_low_idx)
            array.remove(sessionLowActive, oldest_low_idx)
            array.remove(sessionLowBroken, oldest_low_idx)
            array.remove(sessionLowTouched, oldest_low_idx)
    else if oldest_high_idx >= 0
        // Remove high line
        line.delete(array.get(sessionHighLines, oldest_high_idx))
        array.remove(sessionHighLines, oldest_high_idx)
        array.remove(sessionHighVals, oldest_high_idx)
        array.remove(sessionHighBars, oldest_high_idx)
        array.remove(sessionHighSessions, oldest_high_idx)
        array.remove(sessionHighActive, oldest_high_idx)
        array.remove(sessionHighBroken, oldest_high_idx)
        array.remove(sessionHighTouched, oldest_high_idx)
    else if oldest_low_idx >= 0
        // Remove low line
        line.delete(array.get(sessionLowLines, oldest_low_idx))
        array.remove(sessionLowLines, oldest_low_idx)
        array.remove(sessionLowVals, oldest_low_idx)
        array.remove(sessionLowBars, oldest_low_idx)
        array.remove(sessionLowSessions, oldest_low_idx)
        array.remove(sessionLowActive, oldest_low_idx)
        array.remove(sessionLowBroken, oldest_low_idx)
        array.remove(sessionLowTouched, oldest_low_idx)

// SESSION TRACKING
if f_session_started(tokyo_session) and i_tokyo_enabled
    tokyo_session_high := high
    tokyo_session_low := low
    tokyo_session_high_bar := bar_index
    tokyo_session_low_bar := bar_index

if not na(tokyo_session) and i_tokyo_enabled
    if high > tokyo_session_high
        tokyo_session_high := high
        tokyo_session_high_bar := bar_index
    if low < tokyo_session_low
        tokyo_session_low := low
        tokyo_session_low_bar := bar_index

if f_session_started(london_session) and i_london_enabled
    london_session_high := high
    london_session_low := low
    london_session_high_bar := bar_index
    london_session_low_bar := bar_index

if not na(london_session) and i_london_enabled
    if high > london_session_high
        london_session_high := high
        london_session_high_bar := bar_index
    if low < london_session_low
        london_session_low := low
        london_session_low_bar := bar_index

if f_session_started(newyork_session) and i_newyork_enabled
    newyork_session_high := high
    newyork_session_low := low
    newyork_session_high_bar := bar_index
    newyork_session_low_bar := bar_index

if not na(newyork_session) and i_newyork_enabled
    if high > newyork_session_high
        newyork_session_high := high
        newyork_session_high_bar := bar_index
    if low < newyork_session_low
        newyork_session_low := low
        newyork_session_low_bar := bar_index

if f_session_started(sydney_session) and i_sydney_enabled
    sydney_session_high := high
    sydney_session_low := low
    sydney_session_high_bar := bar_index
    sydney_session_low_bar := bar_index

if not na(sydney_session) and i_sydney_enabled
    if high > sydney_session_high
        sydney_session_high := high
        sydney_session_high_bar := bar_index
    if low < sydney_session_low
        sydney_session_low := low
        sydney_session_low_bar := bar_index

// === SESSION HIGH HINZUFÜGEN ===
if f_session_ended(tokyo_session) and i_tokyo_enabled and not na(tokyo_session_high)
    // Check if we need to remove old lines
    while f_count_session_lines("TOKYO") >= i_tokyo_max_lines
        f_remove_oldest_session_line("TOKYO")
    
    val = tokyo_session_high
    bar = tokyo_session_high_bar
    l = line.new(x1=bar, y1=val, x2=bar, y2=val, xloc=xloc.bar_index, color=i_tokyo_high_color, width=i_tokyo_high_width, style=f_get_line_style(i_tokyo_high_style))
    array.push(sessionHighLines, l)
    array.push(sessionHighVals, val)
    array.push(sessionHighBars, bar)
    array.push(sessionHighSessions, "TOKYO")
    array.push(sessionHighActive, true)
    array.push(sessionHighBroken, false)
    array.push(sessionHighTouched, false)

if f_session_ended(london_session) and i_london_enabled and not na(london_session_high)
    // Check if we need to remove old lines
    while f_count_session_lines("LONDON") >= i_london_max_lines
        f_remove_oldest_session_line("LONDON")
    
    val = london_session_high
    bar = london_session_high_bar
    l = line.new(x1=bar, y1=val, x2=bar, y2=val, xloc=xloc.bar_index, color=i_london_high_color, width=i_london_high_width, style=f_get_line_style(i_london_high_style))
    array.push(sessionHighLines, l)
    array.push(sessionHighVals, val)
    array.push(sessionHighBars, bar)
    array.push(sessionHighSessions, "LONDON")
